---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import CensusOfTheGone from '../components/pieces/CensusOfTheGone.jsx';

const piece = PIECES.find(p => p.id === 'census-of-the-gone');
---

<PieceLayout piece={piece}>
  <CensusOfTheGone client:load />
</PieceLayout>
