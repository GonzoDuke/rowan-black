---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import FredsFamousDonuts from '../components/pieces/FredsFamousDonuts.jsx';

const piece = PIECES.find(p => p.id === 'freds-donuts');
---

<PieceLayout piece={piece}>
  <FredsFamousDonuts client:load />
</PieceLayout>
