---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import HudsonParkLibrary from '../components/pieces/HudsonParkLibrary.jsx';

const piece = PIECES.find(p => p.id === 'hudson-park');
---

<PieceLayout piece={piece}>
  <HudsonParkLibrary client:load />
</PieceLayout>
