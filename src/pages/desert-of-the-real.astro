---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import DesertOfTheReal from '../components/poems/DesertOfTheReal.jsx';

const piece = PIECES.find(p => p.id === 'desert-of-the-real');
---

<PieceLayout piece={piece}>
  <DesertOfTheReal client:load />
</PieceLayout>
