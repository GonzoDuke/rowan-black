---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import CityOfGhosts from '../components/pieces/CityOfGhosts.jsx';

const piece = PIECES.find(p => p.id === 'city-of-ghosts');
---

<PieceLayout piece={piece}>
  <CityOfGhosts client:load />
</PieceLayout>
