---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import LateNightNotes from '../components/pieces/LateNightNotes.jsx';

const piece = PIECES.find(p => p.id === 'late-night-notes');
---

<PieceLayout piece={piece}>
  <LateNightNotes client:load />
</PieceLayout>
