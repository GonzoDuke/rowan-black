---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import NightWeDeleteOurMaps from '../components/poems/NightWeDeleteOurMaps.jsx';

const piece = PIECES.find(p => p.id === 'the-night-we-delete');
---

<PieceLayout piece={piece}>
  <NightWeDeleteOurMaps client:load />
</PieceLayout>
