---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import LikeMyPerformance from '../components/poems/LikeMyPerformance.jsx';

const piece = PIECES.find(p => p.id === 'like-my-performance');
---

<PieceLayout piece={piece}>
  <LikeMyPerformance client:load />
</PieceLayout>
