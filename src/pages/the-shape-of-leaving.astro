---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import TheShapeOfLeaving from '../components/poems/TheShapeOfLeaving.jsx';

const piece = PIECES.find(p => p.id === 'the-shape-of-leaving');
---

<PieceLayout piece={piece}>
  <TheShapeOfLeaving client:load />
</PieceLayout>
