---
import BaseLayout from './BaseLayout.astro';

const { piece } = Astro.props;
const pageTitle = `${piece.title} — Rowan Black`;
const ogImage = `/og/${piece.id}.png`;
const ogUrl = `https://placeholder.com/${piece.id}`;

const periodColors = {
  teenage: '#2d8a3e',
  early: '#b08a20',
  transitional: '#3a6a9a',
  mature: '#993333',
  prophetic: '#6a6058',
  unconfirmed: '#c06a1a',
};

const periodColor = periodColors[piece.period] || '#2a6dd4';
---

<BaseLayout title={pageTitle} description={piece.corvidsNote || piece.subtitle || ''} ogImage={ogImage} ogUrl={ogUrl}>
  <div class="piece-page">
    <!-- Nav bar -->
    <nav class="piece-nav">
      <a href="/" class="nav-back">← Archive</a>
      <span class="nav-title">{piece.title}</span>
    </nav>

    <!-- Content card -->
    <div class="piece-card-wrap">
      <div class="piece-card">
        <!-- Header -->
        <div class="piece-header">
          <div class="piece-period" style={`color: ${periodColor}`}>
            {piece.periodLabel} // {piece.year}
          </div>
          <h1 class="piece-title">{piece.title}</h1>
          {piece.subtitle && <div class="piece-subtitle">{piece.subtitle}</div>}
          <div class="piece-form">{piece.form}</div>
        </div>

        <!-- Corvids note -->
        {piece.corvidsNote && (
          <div class="corvids-note">
            <div class="corvids-label">Corvids Collective</div>
            <p class="corvids-text">{piece.corvidsNote}</p>
          </div>
        )}

        <!-- Piece content -->
        <div class="piece-content">
          <slot />
        </div>
      </div>

      <!-- Return footer -->
      <div class="piece-footer">
        <a href="/" class="nav-back">← Back to Archive</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .piece-page {
    background: #dedad4;
    min-height: 100vh;
  }

  .piece-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(222,218,212,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
  }

  .nav-back {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: #2a6dd4;
    text-decoration: none;
    padding: 6px 16px;
    background: #e2e0db;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 5px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .nav-title {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 400;
    color: #9099a8;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 50%;
  }

  .piece-card-wrap {
    max-width: 820px;
    margin: 0 auto;
    padding: 72px 16px 48px;
  }

  .piece-card {
    background: #e2e0db;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .piece-header {
    padding: 32px 36px 28px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .piece-period {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .piece-title {
    font-family: var(--serif);
    font-size: clamp(22px, 4.5vw, 40px);
    font-weight: 400;
    line-height: 1.15;
    color: #1a1d24;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .piece-subtitle {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 300;
    font-style: italic;
    color: #5a6070;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .piece-form {
    font-family: var(--mono);
    font-size: 11px;
    color: #9099a8;
    letter-spacing: 0.04em;
  }

  .corvids-note {
    padding: 20px 36px;
    background: #f8f9fb;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .corvids-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    color: #9099a8;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .corvids-text {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.8;
    color: #5a6070;
    font-weight: 400;
    margin: 0;
  }

  .piece-footer {
    padding: 48px 0 80px;
    text-align: center;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .piece-nav {
      padding: 0 12px;
      height: 44px;
    }

    .nav-back {
      font-size: 12px;
      padding: 5px 12px;
    }

    .nav-title {
      font-size: 11px;
      max-width: 45%;
    }

    .piece-card-wrap {
      padding: 52px 0 32px;
    }

    .piece-card {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }

    .piece-header {
      padding: 24px 16px 20px;
    }

    .corvids-note {
      padding: 16px;
    }

    .piece-footer {
      padding: 32px 0 60px;
    }
  }
</style>
