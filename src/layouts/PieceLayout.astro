---
import BaseLayout from './BaseLayout.astro';

const { piece } = Astro.props;
const pageTitle = `${piece.title} — Rowan Black`;
const ogImage = `/og/${piece.id}.png`;
const ogUrl = `https://placeholder.com/${piece.id}`;

const periodColors = {
  teenage: '#39aa14',
  early: '#b08a20',
  transitional: '#3a6a9a',
  mature: '#993333',
  prophetic: '#2a6dd4',
};

const periodColor = periodColors[piece.period] || '#2a6dd4';
---

<BaseLayout title={pageTitle} description={piece.corvidsNote || piece.subtitle || ''} ogImage={ogImage} ogUrl={ogUrl}>
  <div style="background: #eef0f4; min-height: 100vh;">

    <!-- Nav bar -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(238,240,244,0.92);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,0.08);
      padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 48px;
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 13px; font-weight: 500;
        color: #2a6dd4; text-decoration: none;
        padding: 6px 16px;
        background: #ffffff;
        border: 1px solid rgba(0,0,0,0.1);
        border-radius: 5px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
        transition: all 0.15s;
      `}>← Archive</a>
      <span style={`
        font-family: var(--mono); font-size: 12px; font-weight: 400;
        color: #9099a8;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        max-width: 50%;
      `}>{piece.title}</span>
    </nav>

    <!-- Content card -->
    <div style={`
      max-width: 820px;
      margin: 0 auto;
      padding: 72px 16px 48px;
    `}>
      <div style={`
        background: #ffffff;
        border: 1px solid rgba(0,0,0,0.08);
        border-radius: 8px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.06);
        overflow: hidden;
      `}>
        <!-- Header -->
        <div style={`
          padding: 32px 36px 28px;
          border-bottom: 1px solid rgba(0,0,0,0.06);
        `}>
          <!-- Period indicator -->
          <div style={`
            font-family: var(--mono); font-size: 11px; font-weight: 600;
            color: ${periodColor}; letter-spacing: 0.08em; text-transform: uppercase;
            margin-bottom: 16px;
          `}>
            {piece.periodLabel} // {piece.year}
          </div>

          <!-- Title -->
          <h1 style={`
            font-family: var(--serif); font-size: clamp(26px, 4.5vw, 40px); font-weight: 400;
            line-height: 1.15; color: #1a1d24; letter-spacing: -0.01em;
            margin-bottom: 8px;
          `}>{piece.title}</h1>

          {piece.subtitle && (
            <div style={`
              font-family: var(--serif); font-size: 17px; font-weight: 300;
              font-style: italic; color: #5a6070; line-height: 1.3;
              margin-bottom: 12px;
            `}>{piece.subtitle}</div>
          )}

          <!-- Form label -->
          <div style={`
            font-family: var(--mono); font-size: 11px;
            color: #9099a8; letter-spacing: 0.04em;
          `}>{piece.form}</div>
        </div>

        <!-- Corvids note -->
        {piece.corvidsNote && (
          <div style={`
            padding: 20px 36px;
            background: #f8f9fb;
            border-bottom: 1px solid rgba(0,0,0,0.06);
          `}>
            <div style={`
              font-family: var(--mono); font-size: 10px; font-weight: 600;
              color: #9099a8; letter-spacing: 0.08em;
              text-transform: uppercase; margin-bottom: 8px;
            `}>Corvids Collective</div>
            <p style={`
              font-family: var(--mono); font-size: 13px; line-height: 1.8;
              color: #5a6070; font-weight: 400; margin: 0;
            `}>{piece.corvidsNote}</p>
          </div>
        )}

        <!-- Piece content -->
        <div>
          <slot />
        </div>
      </div>

      <!-- Return footer -->
      <div style="padding: 48px 0 80px; text-align: center;">
        <a href="/" style={`
          font-family: var(--mono); font-size: 13px; font-weight: 500;
          color: #2a6dd4; text-decoration: none;
          padding: 8px 20px;
          background: #ffffff;
          border: 1px solid rgba(0,0,0,0.1);
          border-radius: 5px;
          box-shadow: 0 1px 2px rgba(0,0,0,0.04);
          display: inline-block;
        `}>← Back to Archive</a>
      </div>
    </div>
  </div>
</BaseLayout>
