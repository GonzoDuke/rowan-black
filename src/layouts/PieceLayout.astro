---
import BaseLayout from './BaseLayout.astro';

const { piece } = Astro.props;
const pageTitle = `${piece.title} — Rowan Black`;
const ogImage = `/og/${piece.id}.png`;
const ogUrl = `https://placeholder.com/${piece.id}`;

const periodColors = {
  teenage: '#39ff14',
  early: '#d4a843',
  transitional: '#4a7aaa',
  mature: '#aa4a4a',
  prophetic: '#4a9eff',
};

const periodColor = periodColors[piece.period] || '#4a9eff';
---

<BaseLayout title={pageTitle} description={piece.corvidsNote || piece.subtitle || ''} ogImage={ogImage} ogUrl={ogUrl}>
  <div id="piece-page" style="background: #0a0a0c; min-height: 100vh; position: relative;">

    <!-- Top nav: always visible -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(10,10,12,0.95);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(200,200,208,0.04);
      padding: 0 28px;
      display: flex; align-items: center; justify-content: space-between;
      height: 44px;
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 10px; font-weight: 400;
        letter-spacing: 0.06em; color: rgba(200,200,208,0.35);
        text-decoration: none; transition: color 0.15s;
      `}>← archive</a>
      <span style={`
        font-family: var(--mono); font-size: 10px; font-weight: 300;
        color: rgba(200,200,208,0.15); letter-spacing: 0.04em;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        max-width: 50%;
      `}>{piece.title}</span>
    </nav>

    <!-- Title + Corvids note -->
    <div style={`
      padding: 64px 32px 48px;
      max-width: 800px;
      margin: 0 auto;
    `}>
      <!-- Period indicator: matches homepage directory colors -->
      <div style={`
        font-family: var(--mono); font-size: 9px; font-weight: 400;
        color: ${periodColor}; letter-spacing: 0.12em; text-transform: uppercase;
        margin-bottom: 20px;
      `}>
        {piece.periodLabel} // {piece.year}
      </div>

      <!-- Title -->
      <h1 style={`
        font-family: var(--serif); font-size: clamp(28px, 5vw, 44px); font-weight: 400;
        line-height: 1.1; color: #e8e8f0; letter-spacing: -0.01em;
        margin-bottom: 10px;
      `}>{piece.title}</h1>

      {piece.subtitle && (
        <div style={`
          font-family: var(--serif); font-size: 18px; font-weight: 300;
          font-style: italic; color: rgba(200,200,208,0.4); line-height: 1.3;
          margin-bottom: 16px;
        `}>{piece.subtitle}</div>
      )}

      <!-- Form label -->
      <div style={`
        font-family: var(--mono); font-size: 10px;
        color: rgba(200,200,208,0.15); letter-spacing: 0.04em;
        margin-bottom: 32px;
      `}>{piece.form}</div>

      <!-- Corvids note -->
      {piece.corvidsNote && (
        <div style={`
          border-left: 1px solid rgba(200,200,208,0.06);
          padding-left: 20px;
          max-width: 540px;
        `}>
          <div style={`
            font-family: var(--mono); font-size: 9px; font-weight: 400;
            color: rgba(200,200,208,0.15); letter-spacing: 0.08em;
            text-transform: uppercase; margin-bottom: 10px;
          `}>Corvids Collective</div>
          <p style={`
            font-family: var(--mono); font-size: 12px; line-height: 1.8;
            color: rgba(200,200,208,0.35); font-weight: 300; margin: 0;
          `}>{piece.corvidsNote}</p>
        </div>
      )}

    </div>

    <!-- Piece content: emerges on scroll -->
    <div style={`
      border-top: 1px solid rgba(200,200,208,0.04);
      position: relative;
    `}>
      <slot />
    </div>

    <!-- Return footer -->
    <div style={`
      padding: 80px 28px 120px; text-align: center;
      border-top: 1px solid rgba(200,200,208,0.04);
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 10px; font-weight: 400;
        letter-spacing: 0.06em; color: rgba(200,200,208,0.2);
        text-decoration: none; transition: color 0.15s;
        border: 1px solid rgba(200,200,208,0.08);
        padding: 8px 20px; border-radius: 2px;
        display: inline-block;
      `}>← archive</a>
    </div>
  </div>


</BaseLayout>
