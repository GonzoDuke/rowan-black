---
import BaseLayout from './BaseLayout.astro';

const { piece } = Astro.props;
const pageTitle = `${piece.title} — Rowan Black`;
const ogImage = `/og/${piece.id}.png`;
const ogUrl = `https://placeholder.com/${piece.id}`;

const periodColors = {
  teenage: '#39ff14',
  early: '#d4a843',
  transitional: '#4a7aaa',
  mature: '#aa4a4a',
  prophetic: '#4a9eff',
};

const periodColor = periodColors[piece.period] || '#4a9eff';
---

<BaseLayout title={pageTitle} description={piece.corvidsNote || piece.subtitle || ''} ogImage={ogImage} ogUrl={ogUrl}>
  <div style="background: #222838; min-height: 100vh;">

    <!-- Nav bar -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(30,34,48,0.95);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 48px;
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 12px; font-weight: 400;
        letter-spacing: 0.04em; color: #8899bb;
        text-decoration: none; transition: color 0.15s;
        padding: 6px 14px;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 3px;
      `}>← Back to Archive</a>
      <span style={`
        font-family: var(--mono); font-size: 11px; font-weight: 300;
        color: #667799; letter-spacing: 0.03em;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        max-width: 50%;
      `}>{piece.title}</span>
    </nav>

    <!-- Title + Corvids note -->
    <div style={`
      padding: 72px 32px 48px;
      max-width: 800px;
      margin: 0 auto;
    `}>
      <!-- Period indicator -->
      <div style={`
        font-family: var(--mono); font-size: 11px; font-weight: 500;
        color: ${periodColor}; letter-spacing: 0.1em; text-transform: uppercase;
        margin-bottom: 20px;
      `}>
        {piece.periodLabel} // {piece.year}
      </div>

      <!-- Title -->
      <h1 style={`
        font-family: var(--serif); font-size: clamp(28px, 5vw, 44px); font-weight: 400;
        line-height: 1.1; color: #ffffff; letter-spacing: -0.01em;
        margin-bottom: 10px;
      `}>{piece.title}</h1>

      {piece.subtitle && (
        <div style={`
          font-family: var(--serif); font-size: 18px; font-weight: 300;
          font-style: italic; color: rgba(255,255,255,0.55); line-height: 1.3;
          margin-bottom: 16px;
        `}>{piece.subtitle}</div>
      )}

      <!-- Form label -->
      <div style={`
        font-family: var(--mono); font-size: 11px;
        color: #8899bb; letter-spacing: 0.04em;
        margin-bottom: 32px;
      `}>{piece.form}</div>

      <!-- Corvids note -->
      {piece.corvidsNote && (
        <div style={`
          border-left: 2px solid rgba(255,255,255,0.1);
          padding-left: 20px;
          max-width: 560px;
        `}>
          <div style={`
            font-family: var(--mono); font-size: 10px; font-weight: 500;
            color: #8899bb; letter-spacing: 0.08em;
            text-transform: uppercase; margin-bottom: 10px;
          `}>Corvids Collective</div>
          <p style={`
            font-family: var(--mono); font-size: 13px; line-height: 1.8;
            color: rgba(255,255,255,0.65); font-weight: 300; margin: 0;
          `}>{piece.corvidsNote}</p>
        </div>
      )}
    </div>

    <!-- Piece content -->
    <div style={`
      border-top: 1px solid rgba(255,255,255,0.06);
      position: relative;
    `}>
      <slot />
    </div>

    <!-- Return footer -->
    <div style={`
      padding: 80px 28px 120px; text-align: center;
      border-top: 1px solid rgba(255,255,255,0.06);
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 12px; font-weight: 400;
        letter-spacing: 0.04em; color: #8899bb;
        text-decoration: none; transition: color 0.15s;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 8px 20px; border-radius: 3px;
        display: inline-block;
      `}>← Back to Archive</a>
    </div>
  </div>
</BaseLayout>
